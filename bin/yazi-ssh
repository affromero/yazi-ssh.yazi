#!/usr/bin/env bash
# yazi-ssh — browse remote filesystems in yazi over SSH
# Runs yazi on the server (instant disk I/O), downloads via scp.
set -euo pipefail

VERSION="0.2.0"
PROGRAM="yazi-ssh"

# -----------------------------------------------------------------
# Defaults (overridable via flags or env)
# -----------------------------------------------------------------
DOWNLOAD_DIR="${YAZI_SSH_DOWNLOAD_DIR:-$HOME/Downloads}"

# -----------------------------------------------------------------
# Usage
# -----------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $PROGRAM [options] [user@]host[:path]

Browse remote filesystems in yazi over SSH.
Runs yazi on the server (fast disk I/O), downloads via scp.

Options:
    -i <key>        SSH identity file
    -p <port>       SSH port (default: 22)
    -o <option>     Extra SSH option (repeatable)
    -d <dir>        Local download directory (default: ~/Downloads)
    -h, --help      Show this help
    -v, --version   Show version

Examples:
    $PROGRAM user@myserver
    $PROGRAM -i ~/.ssh/key.pem ubuntu@ec2-host:~/Code
    $PROGRAM -p 2222 user@host:/var/www
    $PROGRAM -d ~/Desktop user@host:~/projects
EOF
}

# -----------------------------------------------------------------
# Parse arguments
# -----------------------------------------------------------------
SSH_BASE_OPTS=()
SCP_BASE_OPTS=()
TARGET=""
PORT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i)
            SSH_BASE_OPTS+=(-i "$2")
            SCP_BASE_OPTS+=(-i "$2")
            shift 2
            ;;
        -p)
            PORT="$2"
            SSH_BASE_OPTS+=(-p "$2")
            SCP_BASE_OPTS+=(-P "$2")
            shift 2
            ;;
        -o)
            SSH_BASE_OPTS+=(-o "$2")
            SCP_BASE_OPTS+=(-o "$2")
            shift 2
            ;;
        -d)
            DOWNLOAD_DIR="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            echo "$PROGRAM $VERSION"
            exit 0
            ;;
        -*)
            echo "Error: unknown option $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            TARGET="$1"
            shift
            ;;
    esac
done

if [[ -z "$TARGET" ]]; then
    echo "Error: no target specified" >&2
    usage >&2
    exit 1
fi

# -----------------------------------------------------------------
# Check local dependencies
# -----------------------------------------------------------------
missing=()
command -v ssh &>/dev/null || missing+=(ssh)
command -v scp &>/dev/null || missing+=(scp)

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Error: missing required commands: ${missing[*]}" >&2
    exit 1
fi

# -----------------------------------------------------------------
# Parse target — [user@]host[:path]
# -----------------------------------------------------------------
REMOTE_HOST="${TARGET%%:*}"
if [[ "$TARGET" == *:* ]]; then
    START_DIR="${TARGET#*:}"
else
    START_DIR="~"
fi

# -----------------------------------------------------------------
# ControlMaster socket and temp files
# -----------------------------------------------------------------
CTL_SOCK="/tmp/yazi-ssh-ctl-$$"
WATCHER_LOG="/tmp/yazi-ssh-downloads-$$.log"
QUEUE_FILE=""
WATCHER_PID=""

# Add ControlMaster settings to SSH opts
SSH_BASE_OPTS+=(-o "ControlPath=$CTL_SOCK")
SCP_BASE_OPTS+=(-o "ControlPath=$CTL_SOCK")

# -----------------------------------------------------------------
# Cleanup
# -----------------------------------------------------------------
cleanup() {
    # Kill local watcher process
    if [[ -n "$WATCHER_PID" ]]; then
        kill "$WATCHER_PID" 2>/dev/null || true
        wait "$WATCHER_PID" 2>/dev/null || true
    fi

    # Remove remote queue file
    if [[ -n "$QUEUE_FILE" ]]; then
        ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
            "rm -f '$QUEUE_FILE'" 2>/dev/null || true
    fi

    # Close ControlMaster
    ssh -O exit -o "ControlPath=$CTL_SOCK" "$REMOTE_HOST" 2>/dev/null || true

    # Print download log if non-empty
    if [[ -s "$WATCHER_LOG" ]]; then
        echo ""
        echo "Downloads:"
        cat "$WATCHER_LOG"
    fi
    rm -f "$WATCHER_LOG"
}
trap cleanup EXIT INT TERM

# -----------------------------------------------------------------
# Download watcher — reads paths from stdin, scp each to local
# -----------------------------------------------------------------
process_downloads() {
    while IFS= read -r remote_path; do
        [[ -z "$remote_path" ]] && continue
        local name
        name="$(basename "$remote_path")"
        echo "[$(date +%H:%M:%S)] Downloading: $name"
        if scp "${SCP_BASE_OPTS[@]}" -o ControlMaster=no -r \
            "${REMOTE_HOST}:${remote_path}" "${DOWNLOAD_DIR}/"; then
            echo "[$(date +%H:%M:%S)] OK: ${DOWNLOAD_DIR}/$name"
        else
            echo "[$(date +%H:%M:%S)] FAILED: $remote_path"
        fi
    done
}

# -----------------------------------------------------------------
# Establish ControlMaster
# -----------------------------------------------------------------
echo "Connecting to ${REMOTE_HOST}..."

if ! ssh "${SSH_BASE_OPTS[@]}" \
    -o ControlMaster=yes \
    -o ServerAliveInterval=15 \
    -o ServerAliveCountMax=3 \
    -fN "$REMOTE_HOST"; then
    echo "Error: could not connect to ${REMOTE_HOST}" >&2
    exit 1
fi

echo "Connected."

# -----------------------------------------------------------------
# Pre-flight checks on server
# -----------------------------------------------------------------
if ! ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
    "command -v yazi" &>/dev/null; then
    echo "Error: yazi is not installed on ${REMOTE_HOST}" >&2
    echo "" >&2
    echo "Install it first:" >&2
    echo "  Ubuntu: cargo install --locked yazi-fm yazi-cli" >&2
    echo "  Arch:   sudo pacman -S yazi" >&2
    echo "  https://yazi-rs.github.io/docs/installation/" >&2
    exit 1
fi

REMOTE_YAZI_VERSION="$(ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
    "yazi --version 2>/dev/null" || echo "unknown")"
echo "Remote yazi: ${REMOTE_YAZI_VERSION}"

# -----------------------------------------------------------------
# Auto-provision plugin on server
# -----------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PLUGIN_SRC="${SCRIPT_DIR}/main.lua"
REMOTE_PLUGIN_DIR="~/.config/yazi/plugins/yazi-ssh.yazi"

if [[ -f "$PLUGIN_SRC" ]]; then
    echo "Provisioning plugin on server..."
    ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
        "mkdir -p ${REMOTE_PLUGIN_DIR}"
    scp "${SCP_BASE_OPTS[@]}" -o ControlMaster=no \
        "$PLUGIN_SRC" "${REMOTE_HOST}:${REMOTE_PLUGIN_DIR}/main.lua"
fi

# -----------------------------------------------------------------
# Auto-provision keymap on server
# -----------------------------------------------------------------
REMOTE_KEYMAP="~/.config/yazi/keymap.toml"

if ! ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
    "grep -q 'yazi-ssh' ${REMOTE_KEYMAP} 2>/dev/null"; then
    echo "Adding keymap binding (m) on server..."
    ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
        "mkdir -p ~/.config/yazi && cat >> ${REMOTE_KEYMAP}" <<'EOF'

[[mgr.prepend_keymap]]
on   = "m"
run  = "plugin yazi-ssh"
desc = "Context menu"
EOF
fi

# -----------------------------------------------------------------
# Auto-provision init.lua on server
# -----------------------------------------------------------------
REMOTE_INIT="~/.config/yazi/init.lua"

if ! ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
    "grep -q 'yazi-ssh' ${REMOTE_INIT} 2>/dev/null"; then
    echo "Adding right-click handler on server..."
    ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
        "mkdir -p ~/.config/yazi && cat >> ${REMOTE_INIT}" <<'EOF'

-- Right-click context menu (yazi-ssh)
local original_entity_click = Entity.click
function Entity:click(event, up)
	if up or event.is_middle then
		return
	end
	ya.emit("reveal", { self._file.url })
	if event.is_right then
		ya.emit("plugin", { "yazi-ssh" })
	else
		original_entity_click(self, event, up)
	end
end
EOF
fi

# -----------------------------------------------------------------
# Create queue file on server
# -----------------------------------------------------------------
QUEUE_FILE="$(ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
    "mktemp /tmp/yazi-ssh-queue-XXXXXX")"
echo "Queue: ${QUEUE_FILE}"

# -----------------------------------------------------------------
# Start download watcher
# -----------------------------------------------------------------
mkdir -p "$DOWNLOAD_DIR"

ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no "$REMOTE_HOST" \
    "tail -n 0 -f '$QUEUE_FILE'" \
    | process_downloads >> "$WATCHER_LOG" 2>&1 &
WATCHER_PID=$!

# -----------------------------------------------------------------
# Launch yazi on the server (foreground, TTY attached)
# -----------------------------------------------------------------
echo "Opening yazi on ${REMOTE_HOST}:${START_DIR}..."
echo ""

ssh "${SSH_BASE_OPTS[@]}" -o ControlMaster=no -t "$REMOTE_HOST" \
    "env YAZI_SSH_REMOTE='$REMOTE_HOST' YAZI_SSH_QUEUE='$QUEUE_FILE' yazi '$START_DIR'"

echo ""
echo "Disconnected."
