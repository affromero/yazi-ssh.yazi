#!/usr/bin/env bash
# yazi-ssh — browse remote filesystems in yazi via sshfs
set -euo pipefail

VERSION="0.1.0"
PROGRAM="yazi-ssh"

# -----------------------------------------------------------------
# Defaults (overridable via flags or env)
# -----------------------------------------------------------------
DOWNLOAD_DIR="${YAZI_SSH_DOWNLOAD_DIR:-$HOME/Downloads}"

# -----------------------------------------------------------------
# Usage
# -----------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $PROGRAM [options] [user@]host[:path]

Browse remote filesystems in yazi via sshfs.

Options:
    -i <key>        SSH identity file
    -p <port>       SSH port (default: 22)
    -o <option>     Extra sshfs/SSH option (repeatable)
    -d <dir>        Local download directory (default: ~/Downloads)
    -h, --help      Show this help
    -v, --version   Show version

Examples:
    $PROGRAM user@myserver
    $PROGRAM -i ~/.ssh/key.pem ubuntu@ec2-host:~/Code
    $PROGRAM -p 2222 user@host:/var/www
    $PROGRAM -d ~/Desktop user@host:~/projects
EOF
}

# -----------------------------------------------------------------
# Parse arguments
# -----------------------------------------------------------------
SSH_OPTS=()
SSHFS_OPTS=()
TARGET=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i)
            SSH_OPTS+=(-o "IdentityFile=$2")
            shift 2
            ;;
        -p)
            SSHFS_OPTS+=(-p "$2")
            shift 2
            ;;
        -o)
            SSHFS_OPTS+=(-o "$2")
            shift 2
            ;;
        -d)
            DOWNLOAD_DIR="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            echo "$PROGRAM $VERSION"
            exit 0
            ;;
        -*)
            echo "Error: unknown option $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            TARGET="$1"
            shift
            ;;
    esac
done

if [[ -z "$TARGET" ]]; then
    echo "Error: no target specified" >&2
    usage >&2
    exit 1
fi

# -----------------------------------------------------------------
# Check dependencies
# -----------------------------------------------------------------
missing=()
command -v sshfs &>/dev/null || missing+=(sshfs)
command -v yazi  &>/dev/null || missing+=(yazi)

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Error: missing required commands: ${missing[*]}" >&2
    echo "" >&2
    echo "Install them first:" >&2
    echo "  macOS:  brew install macfuse sshfs yazi" >&2
    echo "  Ubuntu: sudo apt install sshfs && cargo install --locked yazi-fm yazi-cli" >&2
    echo "  Arch:   sudo pacman -S sshfs yazi" >&2
    exit 1
fi

# -----------------------------------------------------------------
# Parse target — [user@]host[:path]
# -----------------------------------------------------------------
REMOTE_HOST="${TARGET%%:*}"
if [[ "$TARGET" == *:* ]]; then
    REMOTE_PATH="${TARGET#*:}"
else
    REMOTE_PATH=""
fi

# -----------------------------------------------------------------
# Mount
# -----------------------------------------------------------------
MOUNT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/yazi-ssh-XXXXXX")"

cleanup() {
    echo "Unmounting ${MOUNT_DIR}..."
    if [[ "$(uname -s)" == "Darwin" ]]; then
        umount "$MOUNT_DIR" 2>/dev/null \
            || diskutil unmount force "$MOUNT_DIR" 2>/dev/null \
            || true
    else
        fusermount -uz "$MOUNT_DIR" 2>/dev/null \
            || umount -l "$MOUNT_DIR" 2>/dev/null \
            || true
    fi
    rmdir "$MOUNT_DIR" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

SSHFS_SOURCE="${REMOTE_HOST}:${REMOTE_PATH}"
echo "Mounting ${SSHFS_SOURCE} → ${MOUNT_DIR}"

sshfs "$SSHFS_SOURCE" "$MOUNT_DIR" \
    "${SSH_OPTS[@]+"${SSH_OPTS[@]}"}" \
    "${SSHFS_OPTS[@]+"${SSHFS_OPTS[@]}"}" \
    -o reconnect \
    -o ServerAliveInterval=15 \
    -o ServerAliveCountMax=3 \
    -o follow_symlinks

echo "Connected. Opening yazi..."

# -----------------------------------------------------------------
# Launch yazi with SSH metadata for the plugin
# -----------------------------------------------------------------
export YAZI_SSH_REMOTE="$REMOTE_HOST"
export YAZI_SSH_REMOTE_PATH="$REMOTE_PATH"
export YAZI_SSH_MOUNT="$MOUNT_DIR"
export YAZI_SSH_DOWNLOAD_DIR="$DOWNLOAD_DIR"

yazi "$MOUNT_DIR"

echo "Disconnected."
